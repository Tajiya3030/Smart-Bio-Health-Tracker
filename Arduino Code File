#include <Wire.h>
#include "MAX30105.h"
#include "heartRate.h"
#include <LiquidCrystal_I2C.h>
#include "DHT.h"

#define DHTPIN A0
#define DHTTYPE DHT11

DHT dht(DHTPIN, DHTTYPE);
MAX30105 particleSensor;
LiquidCrystal_I2C lcd(0x27, 16, 2);

float h, t, f;
long irValue;
long redValue;
int k;

void setup() {

  Serial.begin(9600);

  if (!particleSensor.begin(Wire, I2C_SPEED_STANDARD)) {
    Serial.println("MAX30102 not found. Check connections.");
    while (true);
  }

  particleSensor.setup();
  
  pinMode(7, INPUT);
  pinMode(11, OUTPUT);
  digitalWrite(11, LOW);

  dht.begin();

  lcd.init();
  lcd.backlight();

  lcd.setCursor(0,0);
  lcd.print("Health Monitor");
  lcd.setCursor(0,1);
  lcd.print("System");
  delay(2000);
  lcd.clear();
}

void loop() {

  for(k=0; k<=59; k++) {

    h = dht.readHumidity();
    t = dht.readTemperature();
    f = dht.readTemperature(true);

    lcd.setCursor(0,0);
    lcd.print("Temp:");
    lcd.print(f);
    lcd.print((char)223);
    lcd.print("F   ");

    irValue = particleSensor.getIR();
    redValue = particleSensor.getRed();

    lcd.setCursor(0,1);
    lcd.print("P:");
    lcd.print(irValue/1100);
    lcd.print("  ");

    lcd.setCursor(8,1);
    lcd.print("O2:");
    lcd.print(redValue/680);
    lcd.print("% ");

    delay(1000);
  }

  sendSMS();
  lcd.clear();
}

void sendSMS() {

  Serial.println("AT+CMGF=1");
  delay(1000);

  Serial.println("AT+CMGS=\"+91XXXXXXXXXX\"");
  delay(1000);

  Serial.print("Temperature:");
  Serial.print(f);
  Serial.println(" F");

  Serial.print("Pulse:");
  Serial.println(irValue/1100);

  Serial.print("SpO2:");
  Serial.print(redValue/680);
  Serial.println("%");

  Serial.write(26);
  delay(1000);
}
